function x89p(){
	base_path="$__69"
	work_dir_name=""
	mode="bb"

	for arg in "$@"; do # parametros --null --69 --ctf (default: bb)
		case "$arg" in
			--null) base_path="$__null" ;;
			--69)   base_path="$__69" ;;
			--ctf)  mode="ctf" ;;
			--bb)		mode="bb" ;;
			*)      work_dir_name="$arg" ;;
		esac
	done

	if [[ -d "${base_path}/${work_dir_name}.${mode}" ]]; then
		echo -e "\xA\x9 -> '${work_dir_name}.${mode}' Already exists: '${base_path}'  | ${mode} | \xA"
		echo -e -n " forzar el ingreso? (y/N): "
		read -r resp
		[[ "$resp" != "y" && "${resp}" != "Y" && "$resp" != "yes" ]] && return 1
	fi
	if [ -z "${work_dir_name}" ]; then
		echo -e -n "\n\t Working dir -> "
		read -r work_dir_name
		if [ -z "${work_dir_name}" ]; then
			work_dir_name="test"
		fi
	fi

	if [ "$mode" = "ctf" ]; then
		x89p_ctf "${base_path}" "${work_dir_name}.${mode}" "${work_dir_name}"
	else
		x89p_bb "${base_path}" "${work_dir_name}.${mode}" "${work_dir_name}"
	fi
}

